{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run vercel-build",
  "framework": "nextjs",
  "rewrites": [{ "source": "/api/:path*", "destination": "/api" }],
  "crons": [
    {
      "path": "/api/cron/db-check",
      "schedule": "0 6 */5 * *"
    }
  ],
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}
