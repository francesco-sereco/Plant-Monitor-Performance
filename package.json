{
  "name": "plant-monitor-performance",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w @pmp/api\" \"npm run dev -w @pmp/web\"",
    "dev:api": "npm run dev -w @pmp/api",
    "dev:web": "npm run dev -w @pmp/web",
    "build": "npm run build -w @pmp/api && npm run build -w @pmp/web",
    "test": "npm run test -w @pmp/api",
    "db:check": "node scripts/verify-supabase.mjs",
    "db:configure": "node scripts/configure-database-url.mjs",
    "db:sync": "node scripts/seed-supabase-rest.mjs",
    "db:migrate": "npm run db:deploy -w @pmp/api",
    "db:deploy": "npm run db:deploy -w @pmp/api",
    "db:seed": "node scripts/seed-supabase-rest.mjs",
    "db:seed:prisma": "npm run db:seed -w @pmp/api",
    "db:reset": "npm run db:reset -w @pmp/api",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "setup:r2": "node scripts/setup-r2.mjs"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.840.0",
    "concurrently": "^9.1.2",
    "dotenv-cli": "^8.0.0"
  }
}
