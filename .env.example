# =============================================================================
# Supabase — SOLO DATI (PostgreSQL via Prisma). Non usare Supabase Storage.
# Dashboard → Project Settings → API
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://kctqmywrtxekvwiynfla.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo backend — MAI esporre nel frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# PostgreSQL (Supabase) — Prisma usa il ruolo pmp_app (creato dallo script di sync)
# In alternativa: Dashboard → Database → Connection string → URI (pooler, porta 5432)
# =============================================================================
DATABASE_URL="postgresql://pmp_app.kctqmywrtxekvwiynfla:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"
SUPABASE_DB_PASSWORD=

# Opzionale: reset password via Management API (https://supabase.com/dashboard/account/tokens)
# SUPABASE_ACCESS_TOKEN=

# =============================================================================
# API Express
# =============================================================================
API_PORT=4000
# API — same-origin in produzione (Next + Express su un solo dominio Vercel)
# Solo dev con server separato: NEXT_PUBLIC_API_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=

# =============================================================================
# Auth (JWT custom — MVP; Supabase Auth in fase successiva)
# =============================================================================
JWT_SECRET=change-me-in-production
AUTH_ENABLED=false

# =============================================================================
# Documenti e file — Cloudflare R2 (privato, download solo via API)
# Setup: CLOUDFLARE_API_TOKEN=xxx npm run setup:r2
# =============================================================================
MAX_PDF_SIZE_MB=25
# r2 = produzione (consigliato) | local = fallback dev senza credenziali R2
STORAGE_BACKEND=r2
STORAGE_PATH=./storage/documents

# Solo backend — MAI esporre nel frontend
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pmp-documents
R2_OBJECT_PREFIX=documents
# Opzionale: token Cloudflare per scripts/setup-r2.mjs (non usato dall'API)
# CLOUDFLARE_API_TOKEN=
